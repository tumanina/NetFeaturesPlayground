{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "api-route": {
        "ClusterId": "api-cluster",
        "Match": {
          "Path": "/api/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "api-cluster": {
        //"LoadBalancingPolicy": "RoundRobin",
        //"LoadBalancingPolicy": "Random",
        "LoadBalancingPolicy": "PowerOfTwoChoices",
        "Destinations": {
          "service1": { "Address": "https://localhost:7221" },
          "service2": { "Address": "https://localhost:7231" },
          "service3": { "Address": "https://localhost:7241" }
        }
      }
    },
    "HealthCheck": {
      "Active": {
        "Enabled": "true",
        "Interval": "00:00:10",
        "Timeout": "00:00:10",
        "Policy": "ConsecutiveFailures",
        "Path": "/health"
      }
    }
  },
  "AllowedHosts": "*"
}
